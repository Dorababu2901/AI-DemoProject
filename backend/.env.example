# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME=Amzur AI Chat
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/api/v1

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/amzur_ai_chat
ASYNC_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/amzur_ai_chat

# ─────────────────────────────────────────────
# Authentication / JWT
# ─────────────────────────────────────────────
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─────────────────────────────────────────────
# LLM Gateway (LiteLLM proxy)
# ─────────────────────────────────────────────
LITELLM_PROXY_URL=
LITELLM_API_KEY=
DEFAULT_LLM_MODEL=gpt-4o-mini

# Image generation (Gemini)
IMAGE_GEN_MODEL=gemini/imagen-4.0-fast-generate-001
GOOGLE_API_KEY=

# ─────────────────────────────────────────────
# Vector store / RAG
# ─────────────────────────────────────────────
VECTOR_STORE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
